# Copy to .env and fill in. All Agent Core settings are read with the ES_ prefix
# (see api/config.py); provider SDK keys (ANTHROPIC_API_KEY, OPENAI_API_KEY) are
# read directly by litellm without a prefix.

ES_DATABASE_URL=postgresql+psycopg://es:es_dev_only@localhost:55432/es
ES_HOST=127.0.0.1
ES_PORT=8731

# JSON array of litellm model strings, tried in order until one succeeds.
# Cloud example:  ES_CODING_MODELS=["claude-sonnet-5","gpt-4o-mini"]
# Local example:  ES_CODING_MODELS=["ollama/qwen2.5-coder"]
ES_CODING_MODELS=[]
ES_FAST_MODELS=[]

# Needed only if you put an ollama/... entry in the lists above.
ES_OLLAMA_BASE_URL=http://localhost:11434

# Provider keys — set whichever provider(s) you're using. Never commit real values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
