# Copy to .env and fill in. All Agent Core settings are read with the ES_ prefix
# (see api/config.py); provider SDK keys (ANTHROPIC_API_KEY, OPENAI_API_KEY) are
# read directly by litellm without a prefix.

ES_DATABASE_URL=postgresql+psycopg://es:es_dev_only@localhost:55432/es
ES_HOST=127.0.0.1
ES_PORT=8731

# JSON array of litellm model strings, tried in order until one succeeds.
# Cloud example:  ES_CODING_MODELS=["claude-sonnet-5","gpt-4o-mini"]
# Local example:  ES_CODING_MODELS=["ollama/qwen2.5-coder"]
ES_CODING_MODELS=[]
ES_FAST_MODELS=[]

# Needed only if you put an ollama/... entry in the lists above.
ES_OLLAMA_BASE_URL=http://localhost:11434

# Provider keys — set whichever provider(s) you're using. Never commit real values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Coding Agent (Phase 1)
ES_SEMGREP_DOCKER_IMAGE=semgrep/semgrep:latest
ES_SEMGREP_TIMEOUT_SECONDS=300
ES_TEST_RUN_TIMEOUT_SECONDS=600
ES_FIX_MAX_FINDINGS_PER_PATCH=5

# Pentest Agent / Tool Orchestrator (Phase 2)
ES_HTTPX_DOCKER_IMAGE=projectdiscovery/httpx:latest
ES_NMAP_DOCKER_IMAGE=instrumentisto/nmap:latest
ES_SUBFINDER_DOCKER_IMAGE=projectdiscovery/subfinder:latest
ES_KATANA_DOCKER_IMAGE=projectdiscovery/katana:latest
ES_NUCLEI_DOCKER_IMAGE=projectdiscovery/nuclei:latest
# No maintained official ffuf image exists — build one locally first:
#   docker build -t es/ffuf:local docker/tools/ffuf
ES_FFUF_DOCKER_IMAGE=es/ffuf:local
ES_DALFOX_DOCKER_IMAGE=hahwul/dalfox:latest
ES_SQLMAP_DOCKER_IMAGE=googlesky/sqlmap:latest
ES_TOOL_TIMEOUT_SECONDS=180
ES_NUCLEI_TIMEOUT_SECONDS=300
ES_FFUF_WORDLIST_PATH=docker/tools/ffuf/wordlist.txt
ES_SCOPE_VERIFICATION_TTL_DAYS=30
# See docs/SECURITY_AND_AUTHORIZATION.md and api/config.py for what this is.
ES_CONTAINER_HOST_ALIAS=host.docker.internal
