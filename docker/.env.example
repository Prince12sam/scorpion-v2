# Copy to docker/.env (gitignored) before `docker compose up`.
# These must match SCORPION_DATABASE_URL in the project root .env.
# (Kept as ES_PG_* here deliberately — these name the existing Postgres
# container/volume, not part of the app's own SCORPION_ settings prefix.)
ES_PG_USER=es
ES_PG_PASSWORD=change_me_dev_only
ES_PG_DB=es
ES_PG_PORT=55432

# Metasploit RPC (msfrpcd) — its own dedicated Postgres, separate schema
# from the one above. MSF_RPC_USER/PASSWORD gate the RPC API itself (not
# the database) — anyone reaching the published port needs these.
MSF_PG_USER=msf
MSF_PG_PASSWORD=change_me_dev_only
MSF_PG_DB=msf
MSF_RPC_USER=msf
MSF_RPC_PASSWORD=change_me_dev_only
MSF_RPC_PORT=55553
